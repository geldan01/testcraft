# Environment variables template for TestCraft
# Copy this file to .env and update the values

# PostgreSQL Database URL for local development
DATABASE_URL="postgresql://testcraft:testcraft@localhost:5432/testcraft?schema=public"

# JWT Secret for authentication (generate a secure random string for production)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Application configuration
NODE_ENV="development"

# File Storage
STORAGE_PROVIDER=local
MAX_FILE_SIZE_MB=50

# S3-Compatible Storage (used when STORAGE_PROVIDER=s3)
# Works with AWS S3, Cloudflare R2, MinIO, DigitalOcean Spaces, Backblaze B2
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=                   # Required for non-AWS services (e.g. https://<account>.r2.cloudflarestorage.com)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Email (optional — if not configured, invitation emails are skipped)
# Supports any SMTP-compatible provider: Resend, Brevo, SendGrid, Mailgun, Amazon SES, etc.
EMAIL_ENABLED=false
EMAIL_FROM="TestCraft <noreply@testcraft.io>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Provider examples:
#   Resend:   SMTP_HOST=smtp.resend.com       SMTP_PORT=465  SMTP_USER=resend        SMTP_PASS=re_your_api_key
#   Brevo:    SMTP_HOST=smtp-relay.brevo.com   SMTP_PORT=587  SMTP_USER=your_email    SMTP_PASS=your_smtp_key
#   SendGrid: SMTP_HOST=smtp.sendgrid.net      SMTP_PORT=587  SMTP_USER=apikey        SMTP_PASS=SG.your_api_key

# Docker Compose Production
APP_PORT=3000
POSTGRES_USER=testcraft
POSTGRES_PASSWORD=testcraft    # Change in production!
POSTGRES_DB=testcraft
